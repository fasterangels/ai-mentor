{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Mentor",
  "version": "0.3.9",
  "identifier": "com.ai.mentor.desktop",
  "build": {
    "beforeDevCommand": "python ../../backend/runner/start_backend.py && npm run dev",
    "beforeBuildCommand": "python ../../backend/runner/start_backend.py && node scripts/inject-build-env.js",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Μέντορας",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://github.com/fasterangels/ai-mentor/releases/latest/download/latest.json"],
      "dialog": false,
      "pubkey": "REPLACE_WITH_PUBLIC_KEY_AFTER_tauri_signer_generate"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/app.ico"],
    "resources": ["bin/ai-mentor-backend.exe", "bin/launch_backend.cmd"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "installerIcon": "icons/app.ico",
        "installMode": "currentUser"
      }
    }
  }
}