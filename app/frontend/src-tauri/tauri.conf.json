{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Mentor",
  "version": "1.0.0",
  "identifier": "com.aimentor.app",
  "build": {
    "beforeDevCommand": "node scripts/inject-build-env.js",
    "beforeBuildCommand": "node scripts/inject-build-env.js",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Μέντορας",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://github.com/fasterangels/ai-mentor/releases/latest/download/latest.json"],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1QzM3MTQ0Qjc0RTlFREIKUldUYm5rNjNSSEhEMVVoSnhmekhvbWZrOUhzSjJQUjBmWTZUUG5uL2xOYWNXc3BjdndCZEJ5T1QK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "resources": ["bin/ai-mentor-backend.exe", "bin/launch_backend.cmd"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  }
}